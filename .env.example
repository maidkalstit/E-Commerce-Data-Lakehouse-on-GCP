# ==============================================================================
# HƯỚNG DẪN: Copy file này thành file '.env' và điền các thông tin thực tế vào.

# ==============================================================================


AIRFLOW_IMAGE_NAME=apache/airflow:2.7.1-python3.10
AIRFLOW_UID=50000

# Khóa mã hóa dữ liệu kết nối trong Airflow (Có thể tạo bằng python: cryptography.fernet.Fernet.generate_key())
AIRFLOW_FERNET_KEY=<YOUR_FERNET_KEY_HERE>
AIRFLOW_WEBSERVER_SECRET_KEY=<YOUR_SECRET_KEY_HERE>

# Tài khoản quản trị nội bộ Postgres (Dành cho Airflow Metadata)
POSTGRES_USER=<YOUR_POSTGRES_USER>
POSTGRES_PASSWORD=<YOUR_POSTGRES_PASSWORD>
POSTGRES_DB=airflow_metadata

# Tài khoản đăng nhập giao diện Web Airflow
# 🔓 Cấu hình BYPASS đăng nhập và tự động bật DAG
AIRFLOW__WEBSERVER__AUTH_BACKEND=airflow.providers.fab.auth_manager.backends.anonymous_auth_backend
AIRFLOW__WEBSERVER__AUTH_ROLE=Admin
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=False

# Thông tin xác thực Google Cloud (Dán toàn bộ nội dung file JSON Service Account vào đây)
GOOGLE_CLOUD_ADC_JSON={"account": "your-service-account@project.iam.gserviceaccount.com", "client_id": "<YOUR_CLIENT_ID>", "client_secret": "<YOUR_CLIENT_SECRET>", "quota_project_id": "<YOUR_PROJECT_ID>"}